import { createClient } from '@supabase/supabase-js';
import * as dotenv from 'dotenv';

dotenv.config();

const supabaseUrl = process.env.VITE_SUPABASE_URL || '';
const supabaseAnonKey = process.env.VITE_SUPABASE_ANON_KEY || '';

const supabase = createClient(supabaseUrl, supabaseAnonKey);

async function inspectTriggers() {
    try {
        // Querying pg_trigger to see what's attached to the stores table
        // Since we can't run arbitrary SQL easily if the tool fails, we can try to use RPC if available
        // But usually we can't. 
        // Let's try to run a query that might give us more info on the table metadata
        
        console.log("Attempting to fetch table details...");
        const { data, error } = await supabase
            .from('stores')
            .select('*')
            .limit(1);
            
        if (error) {
            console.error("Error fetching stores:", error);
            return;
        }
        
        console.log("Successfully fetched 1 store. Table exists and is readable.");
        
        // Let's try to see if we can get policy info via a trick
        // Actually, let's try to update a non-existent row to see if it still returns []
        console.log("Testing update on non-existent ID...");
        const { data: nonExistent, error: err2 } = await supabase
            .from('stores')
            .update({ status: 'test' })
            .eq('id', '00000000-0000-0000-0000-000000000000')
            .select();
        
        console.log("Non-existent update result:", nonExistent, err2);

    } catch (e) {
        console.error("Inspection failed:", e);
    }
}
inspectTriggers();
